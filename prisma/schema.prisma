datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth.js Required Models ─────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?     @map("email_verified")
  image         String?
  isAdmin       Boolean       @default(false) @map("is_admin")
  createdAt     DateTime      @default(now()) @map("created_at")

  accounts      Account[]
  sessions      Session[]
  expenses      Expense[]
  categories    Category[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── App Models ───────────────────────────────────────────────────────────────

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyLimit Decimal? @db.Decimal(12, 2) @map("monthly_limit")
  createdAt DateTime  @default(now()) @map("created_at")
  expenses  Expense[]

  @@unique([userId, name], name: "uq_user_category_name")
  @@map("categories")
}

model Expense {
  id              Int       @id @default(autoincrement())
  description     String
  amount          Decimal   @db.Decimal(12, 2)
  transactionDate DateTime  @map("transaction_date") @db.Date
  categoryId      Int?      @map("category_id")
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId, transactionDate(sort: Desc)], name: "idx_expenses_user_date")
  @@index([categoryId], name: "idx_expenses_category")
  @@map("expenses")
}
